---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AnswerBlock from '../../components/AnswerBlock.astro';
import LeadForm from '../../components/LeadForm.astro';
import { publishedCountySlugs, countyUrl } from '../../lib/links';

// Town pages nest under /locations/. Only non-draft towns generate a page, so a
// town with any open VERIFY field never publishes.
export async function getStaticPaths() {
  const towns = await getCollection('towns', ({ data }) => !data.draft);
  return towns.map((entry) => ({
    params: { town: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const services = await getCollection('services');
const serviceType = new Map(services.map((s) => [s.id, s.data.serviceType]));
const publishedCounties = await publishedCountySlugs();

const path = `/locations/${entry.id}/`;
---

<BaseLayout title={d.title} description={d.description} path={path}>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <Breadcrumbs
      items={[
        { name: 'Home', path: '/' },
        { name: 'Service area', path: '/locations/' },
        { name: d.countyName, path: countyUrl(d.county, publishedCounties) },
        { name: d.name, path },
      ]}
    />

    <h1 class="mt-6 text-3xl sm:text-4xl font-bold text-stone-900">{d.h1}</h1>

    <div class="mt-6">
      <AnswerBlock text={d.answer} />
    </div>

    <div class="prose prose-stone mt-8 max-w-none prose-a:text-emerald-800">
      <Content />
    </div>

    <section class="mt-12 rounded-lg border border-stone-200 bg-white p-6">
      <h2 class="text-xl font-bold text-stone-900">Local detail</h2>
      <dl class="mt-4 space-y-4 text-sm">
        <div><dt class="font-semibold text-stone-900">County</dt><dd class="text-stone-700"><a class="text-emerald-800 hover:underline" href={countyUrl(d.county, publishedCounties)}>{d.countyName}</a></dd></div>
        <div><dt class="font-semibold text-stone-900">Local waterbody or drainage</dt><dd class="text-stone-700">{d.local_waterbody_or_drainage}</dd></div>
        <div><dt class="font-semibold text-stone-900">Local note</dt><dd class="text-stone-700">{d.one_local_detail}</dd></div>
        <div><dt class="font-semibold text-stone-900">Nearest Soil and Water Conservation District</dt><dd class="text-stone-700">{d.nearest_swcd}</dd></div>
      </dl>
    </section>

    <section class="mt-12">
      <h2 class="text-xl font-bold text-stone-900">Services near {d.name}</h2>
      <ul class="mt-4 space-y-2">
        {d.relatedServices.map((slug) => (
          <li><a class="text-emerald-800 hover:underline" href={`/services/${slug}/`}>{serviceType.get(slug) ?? slug}</a></li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-xl font-bold text-stone-900">Before you build</h2>
      <p class="mt-3 text-stone-700">Start with the permit picture for Missouri ponds.</p>
      <p class="mt-2"><a class="font-semibold text-emerald-800 hover:underline" href="/guides/missouri-pond-permit-guide/">Read the Missouri pond permit guide</a></p>
    </section>

    <section class="mt-12">
      <LeadForm />
    </section>
  </div>
</BaseLayout>
