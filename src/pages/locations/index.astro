---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AnswerBlock from '../../components/AnswerBlock.astro';

// Thin bare-links index. Only published (non-draft) location pages are linked.
// County and town pages stay in draft until their VERIFY fields are confirmed,
// so until then this hub names the service area in plain text instead of linking.
const counties = (await getCollection('counties')).sort((a, b) => a.data.name.localeCompare(b.data.name));
const towns = (await getCollection('towns')).sort((a, b) => a.data.name.localeCompare(b.data.name));

const publishedCounties = counties.filter((c) => !c.data.draft);
const publishedTowns = towns.filter((t) => !t.data.draft);

const allCountyNames = counties.map((c) => c.data.name).join(', ');
const allTownNames = towns.map((t) => t.data.name).join(', ');
---

<BaseLayout
  title="Service Area: Southwest Missouri Pond Builders | Ozark Pond Builders"
  description="The southwest Missouri counties and towns where Ozark Pond Builders connects landowners with licensed local pond and excavation contractors."
  path="/locations/"
>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <Breadcrumbs
      items={[
        { name: 'Home', path: '/' },
        { name: 'Service area', path: '/locations/' },
      ]}
    />

    <h1 class="mt-6 text-3xl sm:text-4xl font-bold text-stone-900">Service area</h1>

    <div class="mt-6">
      <AnswerBlock text="Ozark Pond Builders connects landowners across five southwest Missouri counties with licensed local pond and excavation contractors. We focus on the rural county cluster of Greene, Christian, Webster, Polk, and Dallas counties, where pond and lake projects are planned and built." />
    </div>

    {publishedCounties.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-stone-900">Counties</h2>
        <ul class="mt-4 space-y-2">
          {publishedCounties.map((c) => (
            <li><a class="text-emerald-800 hover:underline" href={`/${c.id}/`}>{c.data.name}</a></li>
          ))}
        </ul>
      </section>
    )}

    {publishedTowns.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-stone-900">Towns</h2>
        <ul class="mt-4 space-y-2">
          {publishedTowns.map((t) => (
            <li><a class="text-emerald-800 hover:underline" href={`/locations/${t.id}/`}>{t.data.name}</a></li>
          ))}
        </ul>
      </section>
    )}

    {publishedCounties.length === 0 && publishedTowns.length === 0 && (
      <section class="mt-10 rounded-lg border border-stone-200 bg-white p-6">
        <h2 class="text-xl font-bold text-stone-900">Counties and towns we serve</h2>
        <p class="mt-3 leading-relaxed text-stone-700">
          County and town pages are being finalized with verified local data on soils, watershed, and the local Soil and Water Conservation District office before they go live. In the meantime, we connect landowners across these areas:
        </p>
        <p class="mt-4 font-medium text-stone-900">Counties: {allCountyNames}.</p>
        <p class="mt-2 font-medium text-stone-900">Towns: {allTownNames}.</p>
        <p class="mt-5">
          <a href="/contact/" class="rounded-md bg-emerald-800 px-5 py-3 font-semibold text-white hover:bg-emerald-700 inline-block">Get matched in your area</a>
        </p>
      </section>
    )}

    <section class="mt-12">
      <h2 class="text-xl font-bold text-stone-900">Browse services</h2>
      <ul class="mt-4 space-y-2">
        <li><a class="text-emerald-800 hover:underline" href="/services/farm-and-stock-pond-construction/">Farm and stock pond construction</a></li>
        <li><a class="text-emerald-800 hover:underline" href="/services/recreational-lake-construction/">Recreational lake construction</a></li>
        <li><a class="text-emerald-800 hover:underline" href="/services/pond-dredging-and-renovation/">Pond dredging and renovation</a></li>
        <li><a class="text-emerald-800 hover:underline" href="/services/dam-construction-and-repair/">Dam construction and engineered repair</a></li>
      </ul>
    </section>
  </div>
</BaseLayout>
