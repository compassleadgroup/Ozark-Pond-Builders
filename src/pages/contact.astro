---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AnswerBlock from '../components/AnswerBlock.astro';
import LeadForm from '../components/LeadForm.astro';
import { SITE, telHref } from '../config';
---

<BaseLayout
  title="Contact: Get Matched With a Pond Contractor | Ozark Pond Builders"
  description="Tell us about your pond, lake, or dam project in southwest Missouri. We connect you with one licensed local contractor who can scope and quote it. Free for landowners."
  path="/contact/"
>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <Breadcrumbs items={[{ name: 'Home', path: '/' }, { name: 'Contact', path: '/contact/' }]} />

    <h1 class="mt-6 text-3xl sm:text-4xl font-bold text-stone-900">Get matched with a local contractor</h1>

    <div class="mt-6">
      <AnswerBlock text="Tell us about your pond, lake, dredging, or dam project in southwest Missouri. We connect you with one licensed local pond and excavation contractor who can walk the site, talk through permits and soils, and quote the work. The service is free for landowners, and we are not a contractor ourselves." />
    </div>

    <div class="mt-8">
      <LeadForm heading="Tell us about your project" />
    </div>

    <section class="mt-10 rounded-lg border border-stone-200 bg-white p-6">
      <h2 class="text-xl font-bold text-stone-900">Other ways to reach us</h2>
      <p class="mt-3 text-stone-700">
        Prefer email? Write to <a class="text-emerald-800 underline" href={`mailto:${SITE.email}`}>{SITE.email}</a>.
      </p>
      {SITE.phone ? (
        <p class="mt-2 text-stone-700">
          Or call <a class="text-emerald-800 underline" href={telHref(SITE.phone)}>{SITE.phone}</a>.
        </p>
      ) : (
        <p class="mt-2 text-stone-500">A phone line is coming soon. The form above is the fastest way to start.</p>
      )}
    </section>
  </div>
</BaseLayout>
