---
import { SITE } from '../config';

// Renders a breadcrumb nav and matching BreadcrumbList JSON-LD.
// items: ordered list from Home to the current page. Each item has a path
// (with leading and trailing slash) and a name. The last item is the current page.
interface Crumb {
  name: string;
  path: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    item: SITE.url + item.path,
  })),
};
---
<nav aria-label="Breadcrumb" class="text-sm text-stone-500">
  <ol class="flex flex-wrap items-center gap-x-2 gap-y-1">
    {items.map((item, i) => (
      <li class="flex items-center gap-x-2">
        {i < items.length - 1 ? (
          <a href={item.path} class="hover:text-emerald-800 hover:underline">{item.name}</a>
        ) : (
          <span aria-current="page" class="text-stone-700">{item.name}</span>
        )}
        {i < items.length - 1 && <span aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
