---
// Honest, matching-service explainer. No claims that we perform work.
const steps = [
  {
    n: '1',
    title: 'Tell us about your project',
    body: 'Share your location, the type of pond, lake, or dam work you are planning, and a few details. It takes a couple of minutes and it is free.',
  },
  {
    n: '2',
    title: 'We match you with one local contractor',
    body: 'We connect you with one licensed, local pond and excavation contractor who works in your county and handles projects like yours.',
  },
  {
    n: '3',
    title: 'They scope and quote your work',
    body: 'The contractor you are matched with contacts you to walk the site, talk through permits and soils, and price the project. You decide whether to move forward.',
  },
];
---
<section aria-labelledby="how-heading">
  <h2 id="how-heading" class="text-2xl font-bold text-stone-900">How matching works</h2>
  <ol class="mt-6 grid gap-6 sm:grid-cols-3">
    {steps.map((s) => (
      <li class="rounded-lg border border-stone-200 bg-white p-6">
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-emerald-800 font-bold text-white">{s.n}</span>
        <h3 class="mt-4 font-semibold text-stone-900">{s.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-stone-700">{s.body}</p>
      </li>
    ))}
  </ol>
</section>
