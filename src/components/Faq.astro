---
// Accessible FAQ plus FAQPage JSON-LD. Only include questions the page genuinely
// answers. FAQ rich results were deprecated; this markup is for AI and assistant
// parsing only (see docs/seo-spec.md).
interface Item {
  q: string;
  a: string;
}
interface Props {
  items: Item[];
  heading?: string;
}
const { items, heading = 'Frequently asked questions' } = Astro.props;

const schema =
  items.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: items.map((item) => ({
          '@type': 'Question',
          name: item.q,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.a,
          },
        })),
      }
    : null;
---
{items.length > 0 && (
  <section class="mt-12" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="text-2xl font-bold text-stone-900">{heading}</h2>
    <div class="mt-6 divide-y divide-stone-200 border-y border-stone-200">
      {items.map((item) => (
        <details class="group py-4">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-stone-900">
            <span>{item.q}</span>
            <span class="text-emerald-700 group-open:rotate-45 transition-transform" aria-hidden="true">+</span>
          </summary>
          <p class="mt-3 leading-relaxed text-stone-700">{item.a}</p>
        </details>
      ))}
    </div>
    {schema && <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />}
  </section>
)}
