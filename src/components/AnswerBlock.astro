---
// The AI and human answer block that opens money and guide pages.
// Two to three plain, extractable sentences. Pass text, or use the default slot.
interface Props {
  text?: string;
}
const { text } = Astro.props;
---
<div class="rounded-lg border border-emerald-200 bg-emerald-50 p-5 sm:p-6">
  <p class="text-base sm:text-lg leading-relaxed text-stone-800">
    {text ? text : <slot />}
  </p>
</div>
