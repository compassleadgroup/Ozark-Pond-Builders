---
import { SITE, telHref } from '../config';

// Header disclosure strip text is the verbatim block from COMPLIANCE.md.
const disclosure =
  'Ozark Pond Builders is a free matching service, not a contractor. We connect southwest Missouri landowners with independent, licensed local pond and excavation professionals.';

const services = [
  { href: '/services/farm-and-stock-pond-construction/', label: 'Farm and stock pond construction' },
  { href: '/services/recreational-lake-construction/', label: 'Recreational lake construction' },
  { href: '/services/pond-dredging-and-renovation/', label: 'Pond dredging and renovation' },
  { href: '/services/dam-construction-and-repair/', label: 'Dam construction and engineered repair' },
];

const guides = [
  { href: '/guides/missouri-pond-permit-guide/', label: 'Missouri pond permit guide' },
  { href: '/guides/farm-pond-vs-recreational-pond/', label: 'Farm pond vs recreational pond' },
  { href: '/guides/pond-watershed-sizing/', label: 'Pond watershed sizing' },
  { href: '/guides/will-my-pond-hold-water/', label: 'Will my pond hold water' },
  { href: '/guides/cost-to-build-a-pond-in-missouri/', label: 'Cost to build a pond in Missouri' },
  { href: '/guides/dam-safety-and-spillways/', label: 'Dam safety and spillways' },
];
---

<header class="bg-white">
  {/* Disclosure strip, top of every page, above the fold */}
  <div class="bg-amber-100 text-stone-800 text-center text-xs sm:text-sm px-4 py-2 border-b border-amber-200">
    <p class="mx-auto max-w-5xl">{disclosure}</p>
  </div>

  <div class="border-b border-stone-200">
    <div class="mx-auto max-w-6xl px-4 flex items-center justify-between gap-4 h-16">
      <a href="/" class="font-bold text-lg sm:text-xl text-emerald-900 whitespace-nowrap">
        Ozark Pond Builders
      </a>

      {/* Desktop nav */}
      <nav aria-label="Primary" class="hidden md:flex items-center gap-1 text-sm">
        <details class="group relative">
          <summary class="list-none cursor-pointer select-none rounded px-3 py-2 hover:bg-stone-100">
            Services <span aria-hidden="true">&#9662;</span>
          </summary>
          <div class="absolute right-0 z-40 mt-1 w-72 rounded-lg border border-stone-200 bg-white p-2 shadow-lg">
            {services.map((s) => (
              <a href={s.href} class="block rounded px-3 py-2 hover:bg-stone-100">{s.label}</a>
            ))}
          </div>
        </details>

        <a href="/locations/" class="rounded px-3 py-2 hover:bg-stone-100">Locations</a>

        <details class="group relative">
          <summary class="list-none cursor-pointer select-none rounded px-3 py-2 hover:bg-stone-100">
            Guides <span aria-hidden="true">&#9662;</span>
          </summary>
          <div class="absolute right-0 z-40 mt-1 w-72 rounded-lg border border-stone-200 bg-white p-2 shadow-lg">
            {guides.map((g) => (
              <a href={g.href} class="block rounded px-3 py-2 hover:bg-stone-100">{g.label}</a>
            ))}
          </div>
        </details>

        <details class="group relative">
          <summary class="list-none cursor-pointer select-none rounded px-3 py-2 hover:bg-stone-100">
            About <span aria-hidden="true">&#9662;</span>
          </summary>
          <div class="absolute right-0 z-40 mt-1 w-64 rounded-lg border border-stone-200 bg-white p-2 shadow-lg">
            <a href="/about/" class="block rounded px-3 py-2 hover:bg-stone-100">About us</a>
            <a href="/how-we-vet-contractors/" class="block rounded px-3 py-2 hover:bg-stone-100">How we vet contractors</a>
            <a href="/how-we-make-money/" class="block rounded px-3 py-2 hover:bg-stone-100">How we make money</a>
          </div>
        </details>

        {SITE.phone && (
          <a href={telHref(SITE.phone)} class="rounded px-3 py-2 hover:bg-stone-100">{SITE.phone}</a>
        )}

        <a href="/contact/" class="ml-1 rounded-md bg-emerald-800 px-4 py-2 font-semibold text-white hover:bg-emerald-700">
          Get matched
        </a>
      </nav>

      {/* Mobile menu */}
      <details class="md:hidden relative">
        <summary class="list-none cursor-pointer select-none rounded-md border border-stone-300 px-3 py-2 text-sm">
          Menu
        </summary>
        <div class="absolute right-0 z-40 mt-1 w-72 max-h-[80vh] overflow-auto rounded-lg border border-stone-200 bg-white p-3 shadow-lg text-sm">
          <p class="px-1 pb-1 pt-2 text-xs font-semibold uppercase tracking-wide text-stone-500">Services</p>
          {services.map((s) => (
            <a href={s.href} class="block rounded px-2 py-2 hover:bg-stone-100">{s.label}</a>
          ))}
          <p class="px-1 pb-1 pt-3 text-xs font-semibold uppercase tracking-wide text-stone-500">Guides</p>
          {guides.map((g) => (
            <a href={g.href} class="block rounded px-2 py-2 hover:bg-stone-100">{g.label}</a>
          ))}
          <p class="px-1 pb-1 pt-3 text-xs font-semibold uppercase tracking-wide text-stone-500">More</p>
          <a href="/locations/" class="block rounded px-2 py-2 hover:bg-stone-100">Locations</a>
          <a href="/about/" class="block rounded px-2 py-2 hover:bg-stone-100">About</a>
          <a href="/how-we-vet-contractors/" class="block rounded px-2 py-2 hover:bg-stone-100">How we vet contractors</a>
          <a href="/how-we-make-money/" class="block rounded px-2 py-2 hover:bg-stone-100">How we make money</a>
          {SITE.phone && (
            <a href={telHref(SITE.phone)} class="block rounded px-2 py-2 hover:bg-stone-100">Call {SITE.phone}</a>
          )}
          <a href="/contact/" class="mt-2 block rounded-md bg-emerald-800 px-3 py-2 text-center font-semibold text-white hover:bg-emerald-700">
            Get matched
          </a>
        </div>
      </details>
    </div>
  </div>
</header>
